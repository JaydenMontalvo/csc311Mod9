<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15" prefHeight="600.0" prefWidth="900.0"
      style="-fx-background-color: white;"
      xmlns="http://javafx.com/javafx/20.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="viewmodel.SignUpController">
    <padding>
        <Insets top="60" bottom="60" left="300" right="300" />
    </padding>

    <Label text="Sign Up" textFill="#111386">
        <font><Font name="System Bold" size="36.0" /></font>
    </Label>

    <TextField fx:id="usernameField" promptText="Username"
               prefWidth="300.0" style="-fx-border-color: black; -fx-border-radius: 3;" />

    <TextField fx:id="emailField" promptText="Email (e.g. user@domain.edu)"
               prefWidth="300.0" style="-fx-border-color: black; -fx-border-radius: 3;" />

    <PasswordField fx:id="passwordField" promptText="Password"
                   prefWidth="300.0" style="-fx-border-color: black; -fx-border-radius: 3;" />

    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password"
                   prefWidth="300.0" style="-fx-border-color: black; -fx-border-radius: 3;" />

    <Label fx:id="statusLabel" text="" wrapText="true"
           style="-fx-text-fill: red; -fx-font-size: 13px;" />

    <Button fx:id="newAccountBtn" text="Create New Account"
            onAction="#createNewAccount" prefWidth="300.0" prefHeight="40.0"
            style="-fx-background-color: #444; -fx-text-fill: white; -fx-border-color: black; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5;" />

    <Button fx:id="goBackBtn" text="Back to Login"
            onAction="#goBack" prefWidth="300.0" prefHeight="40.0"
            style="-fx-background-color: #888; -fx-text-fill: white; -fx-border-color: black; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5;" />
</VBox>
